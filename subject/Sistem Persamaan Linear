  <!-- 5. Representasi Matriks  -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-card" id="Matriks">
    <div class="section-header">
      <div class="section-num">5</div>
      <h2>Representasi Matriks</h2>
    </div>
    <p>
Sistem Persamaan Linear (SPL) dapat ditulis dalam bentuk matriks agar lebih 
ringkas dan mudah dihitung, terutama jika jumlah variabel banyak.
</p>

<div class="example-box">
<strong>Bentuk umum SPL:</strong><br><br>

a₁₁x₁ + a₁₂x₂ + a₁₃x₃ = b₁ <br>
a₂₁x₁ + a₂₂x₂ + a₂₃x₃ = b₂ <br>
a₃₁x₁ + a₃₂x₂ + a₃₃x₃ = b₃
</div>

<p>
Bentuk tersebut dapat ditulis dalam bentuk matriks:
<strong>Ax = b</strong>
</p>

<!-- MATRIX UTAMA -->
<div class="matrix-classic">

    <div class="bracket left"></div>
    <div class="matrix-content">
        a₁₁&nbsp;&nbsp;a₁₂&nbsp;&nbsp;a₁₃ <br>
        a₂₁&nbsp;&nbsp;a₂₂&nbsp;&nbsp;a₂₃ <br>
        a₃₁&nbsp;&nbsp;a₃₂&nbsp;&nbsp;a₃₃
    </div>
    <div class="bracket right"></div>

    <div style="margin: 0 12px;">×</div>

    <div class="bracket left"></div>
    <div class="matrix-content">
        x₁ <br>
        x₂ <br>
        x₃
    </div>
    <div class="bracket right"></div>

    <div style="margin: 0 12px;">=</div>

    <div class="bracket left"></div>
    <div class="matrix-content">
        b₁ <br>
        b₂ <br>
        b₃
    </div>
    <div class="bracket right"></div>

</div>

<!-- PENJELASAN -->
<div class="example-box">
<strong>Keterangan:</strong>
<ul>
<li><b>A</b> = matriks koefisien</li>
<li><b>x</b> = matriks variabel</li>
<li><b>b</b> = matriks konstanta</li>
</ul>
</div>

<!-- CONTOH -->
<h3>🔸 Contoh Nyata</h3>

<div class="example-box">

<p><strong>Diketahui:</strong></p>

2x + y + z = 9 <br>
